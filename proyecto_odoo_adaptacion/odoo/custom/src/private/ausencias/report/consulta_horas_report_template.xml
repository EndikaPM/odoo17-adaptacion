<odoo>

    <template id="report_consulta_horas" name="Reporte: Horas por Empleado">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page">
                    <div class="header-section">
                        <h1>Reporte de Horas por Empleado</h1>
                        <p>
                            <strong>Fecha de Generacion:</strong>
                            <t t-out="generated_at.strftime('%d/%m/%Y %H:%M')" />
                        </p>
                    </div>


                    <table class="table table-striped table-hover">
                        <thead>
                            <tr>
                                <th class="col-nombre">Nombre</th>
                                <th class="col-dni">DNI</th>
                                <th class="col-horas text-right">Contrato Anual</th>
                                <th class="col-horas text-right">Contrato / Mes</th>
                                <th class="col-horas text-right">Horas Trabajadas</th>
                                <th class="col-horas text-right">Horas Extra</th>
                                <th class="col-estado">Estado</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="rows" t-as="row">
                                <tr t-att-class="'row-' + row['extra_style']">
                                    <td class="col-nombre"><t
                                            t-out="row['nombre']"
                                        /></td>
                                    <td class="col-dni"><t t-out="row['dni']" /></td>
                                    <td class="col-horas text-right"><t
                                            t-out="'{:.2f}'.format(row['horas_contrato_anual'])"
                                        /></td>
                                    <td class="col-horas text-right"><t
                                            t-out="'{:.2f}'.format(row['horas_contrato_mes'])"
                                        /></td>
                                    <td class="col-horas text-right"><t
                                            t-out="'{:.2f}'.format(row['horas_trabajadas'])"
                                        /></td>
                                    <td
                                        class="col-horas text-right"
                                        t-att-style="'color: ' + ('green' if row['horas_extra'] &lt;= 0 else 'red') + '; font-weight: bold;'"
                                    >
                                        <t
                                            t-out="'{:.2f}'.format(row['horas_extra'])"
                                        />
                                    </td>
                                    <td class="col-estado">
                                        <span
                                            t-att-class="'badge badge-' + row['extra_style']"
                                        >
                                            <t t-out="row['extra_label']" />
                                        </span>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>

                </div>
            </t>
        </t>
    </template>

    <record id="action_report_consulta_horas" model="ir.actions.report">
        <field name="name">Horas por Empleado (PDF)</field>
        <field name="model">ausencias.consulta.horas</field>
        <field name="binding_model_id" ref="model_ausencias_consulta_horas" />
        <field name="binding_type">report</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">ausencias.report_consulta_horas</field>
        <field name="print_report_name">'Horas_por_Empleado'</field>
    </record>
</odoo>
