<odoo>
    <!-- ============================================================ -->
    <!-- Vista TREE – Solicitudes de ausencia (solo lectura)          -->
    <!-- ============================================================ -->
    <record id="view_consulta_solicitudes_tree" model="ir.ui.view">
        <field name="name">ausencias.consulta.solicitudes.tree</field>
        <field name="model">ausencias.consulta.solicitudes</field>
        <field name="arch" type="xml">
            <tree
                string="Solicitudes de Ausencia"
                create="false"
                edit="false"
                delete="false"
            >
                <header>
                    <!-- Botón Imprimir PDF directamente en la vista tree -->
                    <button
                        name="%(action_report_consulta_solicitudes)d"
                        string="Imprimir PDF"
                        type="action"
                        class="btn-primary"
                    />
                </header>
                <field name="nombre" />
                <field name="tipo_motivo" />
                <field name="fecha_inicio" />
                <field name="fecha_fin" />
                <field name="hora_inicio" widget="float_time" />
                <field name="hora_fin" widget="float_time" />
                <field name="dias_solicitados" />
            </tree>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Vista SEARCH – filtros rápidos                               -->
    <!-- ============================================================ -->
    <record id="view_consulta_solicitudes_search" model="ir.ui.view">
        <field name="name">ausencias.consulta.solicitudes.search</field>
        <field name="model">ausencias.consulta.solicitudes</field>
        <field name="arch" type="xml">
            <search string="Buscar solicitud">
                <field name="nombre" />
                <field name="tipo_motivo" />
                <filter
                    name="vacaciones"
                    string="Vacaciones"
                    domain="[('tipo_motivo', '=', 'VACACIONES')]"
                />
                <filter
                    name="medico"
                    string="Médico"
                    domain="[('tipo_motivo', '=', 'MEDICO')]"
                />
                <filter
                    name="asuntos"
                    string="Asuntos Propios"
                    domain="[('tipo_motivo', '=', 'ASUNTOS')]"
                />
                <group expand="0" string="Agrupar por">
                    <filter name="group_empleado" string="Empleado" context="{'group_by': 'nombre'}" />
                    <filter name="group_motivo" string="Motivo" context="{'group_by': 'tipo_motivo'}" />
                </group>
            </search>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Acción para abrir la consulta                                -->
    <!-- ============================================================ -->
    <record id="action_consulta_solicitudes" model="ir.actions.act_window">
        <field name="name">Solicitudes de Ausencia</field>
        <field name="res_model">ausencias.consulta.solicitudes</field>
        <field name="view_mode">tree</field>
        <field name="search_view_id" ref="view_consulta_solicitudes_search" />
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No hay solicitudes de ausencia registradas.
            </p>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Menú: Ausencias ▸ Consultas ▸ Solicitudes de Ausencia        -->
    <!-- ============================================================ -->
    <menuitem
        id="menu_consulta_solicitudes"
        name="Solicitudes de Ausencia"
        parent="menu_ausencias_consultas"
        action="action_consulta_solicitudes"
        sequence="20"
    />
</odoo>

